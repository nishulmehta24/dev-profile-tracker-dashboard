# DevPulse Backend Environment Configuration Example
# Duplicate this file as '.env' and fill in your details. Do NOT commit your actual '.env' to git!

PORT=5000

# MongoDB URI: Replace with your local database URL or MongoDB Atlas cloud connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/devpulse?retryWrites=true&w=majority

# JWT Cryptographic Signing Secret (Change this to a strong random passphrase)
JWT_SECRET=your_32_character_cryptographic_secret_key_here
